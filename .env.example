# Copy this file to .env for local dev
# See google-apps-script/Code.js for Google Script setup

VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# GitHub Pages: add the same variable as a repository secret
# Repo → Settings → Secrets and variables → Actions → New repository secret
# Name: VITE_GOOGLE_SCRIPT_URL
# Value: your /exec URL (rebuild/redeploy after adding)
